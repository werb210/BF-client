{
  "name": "bf-client-root",
  "private": true,
  "workspaces": [
    "client-app"
  ],
  "overrides": {
    "esbuild": "0.18.20",
    "serialize-javascript": "6.0.1"
  },
  "packageManager": "npm@10",
  "engines": {
    "node": ">=20.10 <23"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "preinstall": "npm config delete @eslint:registry || true",
    "build": "npm --prefix client-app run build",
    "test": "npm --prefix client-app run test",
    "dev": "npm --prefix client-app run dev"
  }
}