{
  "name": "client-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run enforce:api && vite build",
    "preview": "vite preview --port 5173",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run --passWithNoTests",
    "test:ci": "vitest --run",
    "audit:enterprise": "node scripts/enterprise-audit.js",
    "prestart": "node scripts/verify-node.js",
    "smoke": "npm run build",
    "check": "npm run enforce:api && tsc --noEmit",
    "cap:sync": "cap sync",
    "cap:open:ios": "cap open ios",
    "cap:open:android": "cap open android",
    "enforce:api": "node scripts/enforce-api-pipeline.js",
    "preview:ci": "vite preview --port 4173 & sleep 3 && curl -f http://localhost:4173"
  },
  "engines": {
    "node": ">=20.10 <23"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.56.20",
    "@twilio/voice-sdk": "^2.13.0",
    "classnames": "^2.5.1",
    "clsx": "^2.1.0",
    "jwt-decode": "^4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.1.1",
    "uuid": "^11.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^22.5.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.27",
    "depcheck": "^1.4.7",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "html2canvas": "^1.4.1",
    "jsdom": "^24.0.0",
    "lodash.debounce": "^4.0.8",
    "madge": "^8.0.0",
    "npm-check-updates": "^17.1.12",
    "postcss": "^8.5.8",
    "semver": "^7.6.3",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.46.2",
    "vite": "^4.5.14",
    "vite-plugin-pwa": "^0.20.0",
    "vitest": "^2.1.1"
  },
  "engineStrict": true
}
