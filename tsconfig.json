{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@/*": ["client-app/src/*"]
    },
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false
  },
  "include": ["client-app/src"]
}
